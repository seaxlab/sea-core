<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.seaxlab.core.dal.mybatis.tk.User1Mapper">

    <resultMap id="userResultMap" type="com.github.seaxlab.core.dal.mybatis.tk.User1">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="age" column="age"/>
        <result property="email" column="email"/>
        <result property="cardNo" column="card_no"/>
        <result property="createTime" jdbcType="TIMESTAMP" column="create_time"/>
    </resultMap>


    <sql id="Base_Column_List">
        id, name,age,email,card_no, create_time
    </sql>


    <select id="queryHistory" parameterType="int" resultMap="userResultMap">
        select *
        from user1
        where create_time &lt;= date_add(now(), interval #{delayMinute} minute)

    </select>
</mapper>