{
  "groups": [
    {
      "name": "sea",
      "type": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties"
    }
  ],
  "properties": [
    {
      "name": "sea.region",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "default",
      "description": "区域，jiangsu/shandong/-idc."
    },
    {
      "name": "sea.env",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "pro",
      "description": "环境标识，local/dev/test/uat/sit/pre/pro."
    },
    {
      "name": "sea.profile",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "",
      "description": "profile for sub env, uat2,uat3."
    },
    {
      "name": "sea.app-name",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "${spring.application.name}",
      "description": "sea application name."
    },
    {
      "name": "sea.schedule-thread-context-enable",
      "type": "java.lang.Boolean",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "false",
      "description": "是否需要开启@scheduled注解清理上下文，默认false"
    },
    {
      "name": "sea.schedule-thread-context-base-package",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "",
      "description": "schedule需要清理thread context包路径，需符合aspectj pointcut expression规范,默认所有@Scheduled注解，例如execution(public * com.github.spy..*.*(..))."
    },
    {
      "name": "sea.fastjson.enable",
      "type": "java.lang.Boolean",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": true,
      "description": "是否启用FastJSON作为消息处理."
    },
    {
      "name": "sea.fastjson.writeNullValue",
      "type": "java.lang.Boolean",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": false,
      "description": "FastJSON中是否输出空值."
    },
    {
      "name": "sea.redis.host",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "",
      "description": "redis host."
    },
    {
      "name": "sea.redis.port",
      "type": "java.lang.Integer",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "",
      "description": "redis port."
    },
    {
      "name": "sea.redis.password",
      "type": "java.lang.String",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "",
      "description": "redis auth password."
    },
    {
      "name": "sea.redis.database",
      "type": "java.lang.Integer",
      "sourceType": "com.github.spy.sea.core.boot.autoconfigure.SeaProperties",
      "defaultValue": "0",
      "description": "redis database."
    }
  ]
}