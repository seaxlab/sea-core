#
# Application Listeners
org.springframework.context.ApplicationListener=\
com.github.spy.sea.core.boot.autoconfigure.listener.ApplicationInitListener
#
# auto configuration.
org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
com.github.spy.sea.core.boot.autoconfigure.SeaCoreAutoConfigure,\
com.github.spy.sea.core.boot.autoconfigure.SeaCoreWebAutoConfiguration,\
com.github.spy.sea.core.boot.autoconfigure.SeaCoreWebFluxAutoConfiguration
